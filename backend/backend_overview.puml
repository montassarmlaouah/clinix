@startuml
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam packageTitleFontSize 25
skinparam packageTitleFontColor #1A237E

' ===========================
' SUPER ADMINISTRATEUR
' ===========================
package "1️⃣ Super Administrateur" #E3F2FD {
    actor "Super Admin" as SA

    usecase "S'enregistrer" as SA_REG
    usecase "Se connecter" as SA_LOGIN

    usecase "Gérer cliniques" as SA1
    usecase "Créer admin clinique" as SA2
    usecase "Gérer abonnements" as SA3
    usecase "Consulter KPI globaux" as SA4
    usecase "Comparer performances" as SA5

    SA --> SA_REG
    SA --> SA_LOGIN

    SA1 ..> SA_LOGIN : <<include>>
    SA2 ..> SA_LOGIN : <<include>>
    SA3 ..> SA_LOGIN : <<include>>
    SA4 ..> SA_LOGIN : <<include>>
    SA5 ..> SA_LOGIN : <<include>>
}


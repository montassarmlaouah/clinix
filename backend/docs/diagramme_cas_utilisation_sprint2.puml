@startuml
!theme plain

title Diagramme de cas d'utilisation - Organisation et abonnements (Sprint 2)

left to right direction
skinparam packageStyle rectangle

actor "Super administrateur" as SA
actor "Administrateur clinique" as AC
actor "Medecin (cabinet)" as MED
actor "Secretaire" as SEC
actor "Stripe" as Stripe

rectangle "Module Organisationnel" {
  usecase "Consulter la liste des cliniques" as UC1
  usecase "Creer / modifier une clinique" as UC2
  usecase "Activer / desactiver une clinique" as UC3
  usecase "Consulter le detail d'une clinique" as UC4
  usecase "Gerer les cabinets medicaux" as UC5

  usecase "Consulter la liste du personnel" as UC6
  usecase "Creer / modifier / desactiver un compte personnel" as UC7
  usecase "Gerer les services medicaux" as UC8
}

rectangle "Module Abonnement (SaaS)" {
  usecase "Gerer les offres d'abonnement (CRUD)" as AB1
  usecase "Activer / desactiver une offre" as AB2
  usecase "Synchroniser les offres avec Stripe" as AB3
  usecase "Souscrire et payer un abonnement" as AB4
  usecase "Consulter l'abonnement courant + historique" as AB5
  usecase "Traiter les webhooks Stripe" as AB6
}

SA --> UC1
SA --> UC2
SA --> UC3
SA --> UC4
SA --> UC5
SA --> AB1
SA --> AB2
SA --> AB3

AC --> UC6
AC --> UC7
AC --> UC8
AC --> AB4
AC --> AB5

MED --> AB4
MED --> AB5
SEC --> AB5

UC2 ..> UC3 : <<extend>>
AB1 ..> AB2 : <<extend>>
AB4 ..> AB6 : <<include>>
Stripe --> AB6

@enduml

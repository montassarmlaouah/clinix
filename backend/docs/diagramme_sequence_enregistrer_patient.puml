@startuml
!theme plain

title sd [Enregistrer un patient]

autonumber

actor Secretaire
boundary UI as ":UI Patients"
control Controller as "PatientController"
control Service as "PatientService"
entity DAO as "PatientRepository"

ref over Secretaire, UI
  S'authentifier
end ref

Secretaire -> UI : 1 : Ouvrir formulaire nouveau patient
UI --> Secretaire : 2 : Afficher formulaire
Secretaire -> UI : 3 : Saisir identite, contact, assurance, CIN
Secretaire -> UI : 4 : Confirmer l'enregistrement
UI -> Controller : 5 : POST /api/patients
Controller -> Service : 6 : creerPatient(dto)
Service -> DAO : 7 : existsByCin(cin)

alt CIN deja existant
  DAO --> Service : 8 : true
  Service --> Controller : 9 : Erreur unicite CIN
  Controller --> UI : 10 : 409 Conflict
  UI --> Secretaire : 11 : Afficher message CIN deja utilise
else CIN unique et donnees valides
  DAO --> Service : 8 : false
  Service -> DAO : 9 : save(patient)
  Service -> Service : 10 : Creer dossier medical associe
  Service --> Controller : 11 : Patient + dossier
  Controller --> UI : 12 : 201 Created
  UI --> Secretaire : 13 : Afficher patient enregistre
end

@enduml

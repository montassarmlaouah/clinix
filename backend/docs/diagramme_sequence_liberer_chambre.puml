@startuml
!theme plain

title sd [Liberer une chambre (sortie patient)]

autonumber

actor Secretaire
boundary UI as ":UI Liste chambres"
control Controller as "HospitalisationController"
control Service as "HospitalisationService"
entity ChambreDAO as "ChambreRepository"
entity HospDAO as "HospitalisationRepository"

ref over Secretaire, UI
  S'authentifier
end ref

Secretaire -> UI : Cliquer sur Sortie patient (chambre occupee)
UI --> Secretaire : Afficher formulaire de sortie (date de sortie)
Secretaire -> UI : Saisir la date de sortie et confirmer
UI -> Controller : PATCH /api/hospitalisations/{id}/terminer?dateSortie=...
Controller -> Service : terminerHospitalisation(id, dateSortie)
Service -> HospDAO : findById(id)
HospDAO --> Service : Hospitalisation

alt [Hospitalisation deja terminee]
  Service --> Controller : RuntimeException
  Controller --> UI : 400 Bad Request
  UI --> Secretaire : Afficher message d'erreur
else [Sortie valide]
  Service -> Service : dateSortie + statut = TERMINEE
  Service -> ChambreDAO : save(chambre.disponible = true)
  ChambreDAO --> Service : Chambre liberee
  Service -> HospDAO : save(hospitalisation)
  HospDAO --> Service : Hospitalisation terminee
  Service --> Controller : Hospitalisation
  Controller --> UI : 200 OK
  UI -> UI : Rafraichir la liste des chambres
  UI --> Secretaire : Afficher "Chambre liberee"
end

note over Secretaire, HospDAO
  La sortie peut declencher ensuite
  la generation de facture (Sprint 5).
end note

@enduml

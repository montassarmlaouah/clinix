@startuml
!theme plain

title Diagramme de cas d'utilisation - Pharmacie et stocks (Sprint 4)

left to right direction
skinparam packageStyle rectangle

actor "Pharmacien" as PHA
actor "Medecin" as MED
actor "Infirmier" as INF

rectangle "Module Pharmacie" {
  usecase "Gerer le catalogue des medicaments" as UC1
  usecase "Gerer le stock (mouvements)" as UC2
  usecase "Visualiser les alertes de stock bas" as UC3
  usecase "Creer un bon d'entree" as UC4
  usecase "Envoyer une demande de medicament" as UC5
  usecase "Traiter une demande (valider / refuser)" as UC6
  usecase "Consulter l'historique des demandes" as UC7
}

PHA --> UC1
PHA --> UC2
PHA --> UC3
PHA --> UC4
PHA --> UC6
PHA --> UC7

MED --> UC5
INF --> UC5

UC4 ..> UC2 : <<include>>
UC6 ..> UC2 : <<include>>
UC2 ..> UC3 : <<extend>>

@enduml

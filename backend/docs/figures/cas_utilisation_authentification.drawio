        <!-- Frontière système -->
        <mxCell id="system-boundary" value="Cas d'utilisation authentification" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=10;fillColor=none;strokeColor=#000000;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="200" y="50" width="720" height="520" as="geometry" />
        </mxCell>

        <!-- Cas d'utilisation -->
        <mxCell id="uc-deconnecter" value="Se déconnecter" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="280" y="100" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="uc-connecter" value="Se connecter" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="400" y="220" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="uc-profil" value="Consulter profil" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;" vertex="1" parent="1">

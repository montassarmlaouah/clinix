        <!-- mot passe oublié <<extend>> Se connecter -->
        <mxCell id="rel-extend-forgot" value="&amp;lt;&amp;lt;extend&amp;gt;&amp;gt;" style="endArrow=open;dashed=1;html=1;rounded=0;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="uc-forgot" target="uc-connecter">
          <mxGeometry relative="1" as="geometry" />

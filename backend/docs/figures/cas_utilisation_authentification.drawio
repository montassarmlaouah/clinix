        </mxCell>
        <mxCell id="uc-roles" value="Gérer rôles" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="680" y="100" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="uc-redirect" value="Se rediriger vers le dashboard" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="640" y="250" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="uc-forgot" value="mot passe oublié" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="400" y="380" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="uc-reset" value="Réinitialiser MDP" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;" vertex="1" parent="1">

        <!-- Se connecter <<include>> Se rediriger vers le dashboard -->
        <mxCell id="rel-include-redirect" value="&amp;lt;&amp;lt;include&amp;gt;&amp;gt;" style="endArrow=open;dashed=1;html=1;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="uc-connecter" target="uc-redirect">

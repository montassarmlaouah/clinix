@startuml
!theme plain

title sd [Affecter une chambre a un patient]

autonumber

actor Secretaire
boundary UI as ":UI Liste chambres"
control Controller as "HospitalisationController"
control Service as "HospitalisationService"
entity ChambreDAO as "ChambreRepository"
entity HospDAO as "HospitalisationRepository"
entity PatientDAO as "PatientRepository"

ref over Secretaire, UI
  S'authentifier
end ref

Secretaire -> UI : Cliquer sur Affecter un patient (chambre disponible)
UI --> Secretaire : Afficher formulaire (patient, medecin, date entree, motif)
Secretaire -> UI : Selectionner patient + medecin + saisir les informations
Secretaire -> UI : Confirmer l'affectation
UI -> Controller : POST /api/hospitalisations
Controller -> Service : creerHospitalisation(hospitalisation)
Service -> PatientDAO : findById(patientId)
PatientDAO --> Service : Patient

Service -> ChambreDAO : findById(chambreId)
ChambreDAO --> Service : Chambre

alt [Chambre deja occupee / non disponible]
  Service --> Controller : RuntimeException "Chambre non disponible"
  Controller --> UI : 400 Bad Request
  UI --> Secretaire : Afficher message d'erreur
else [Chambre disponible]
  Service -> ChambreDAO : save(chambre.disponible = false)
  ChambreDAO --> Service : Chambre mise a jour
  Service -> Service : statut = EN_COURS
  Service -> HospDAO : save(hospitalisation)
  HospDAO --> Service : Hospitalisation creee
  Service --> Controller : Hospitalisation
  Controller --> UI : 201 Created
  UI -> UI : Rafraichir la liste des chambres
  UI --> Secretaire : Afficher message de succes
end

@enduml

@startuml
!theme plain

title sd [Creer une demande d'operation]

autonumber

actor Medecin
boundary UI as ":UI Demandes operation"
control Controller as "DemandeOperationController"
control Service as "DemandeOperationService"
entity DemandeDAO as "DemandeOperationRepository"
entity PatientDAO as "PatientRepository"
entity UserDAO as "UserRepository"

ref over Medecin, UI
  S'authentifier
end ref

Medecin -> UI : Cliquer Creer une demande
UI --> Medecin : Afficher formulaire (patient, type, urgence, description)
Medecin -> UI : Remplir et confirmer la demande
UI -> Controller : POST /api/demandes-operation
Controller -> Service : creer(demandeurId, request)
Service -> UserDAO : findById(demandeurId)
UserDAO --> Service : Medecin (demandeur)
Service -> PatientDAO : findById(patientId)
PatientDAO --> Service : Patient

alt [Donnees invalides (type vide, patient inconnu)]
  Service --> Controller : IllegalArgumentException
  Controller --> UI : 400 Bad Request
  UI --> Medecin : Afficher message d'erreur
else [Demande valide]
  Service -> Service : statut = EN_ATTENTE, priorite, clinique
  Service -> DemandeDAO : save(demande)
  DemandeDAO --> Service : DemandeOperation
  Service --> Controller : DemandeOperation
  Controller --> UI : 200 OK
  UI --> Medecin : Afficher demande creee (en attente de traitement)
end

note over Medecin, DemandeDAO
  L'admin clinique traite ensuite la demande
  (Approuver, Refuser, Planifier, Effectuer).
  Voir : diagramme_sequence_traiter_demande_operation.puml
end note

@enduml

@startuml
!theme plain

title sd [Traiter une demande de medicament]

autonumber

actor Pharmacien
actor Demandeur as "Medecin / Infirmier"
boundary UI as ":UI Demandes medicament"
control Controller as "DemandeMedicamentController"
control Service as "DemandeMedicamentService"
control Stock as "StockMedicamentService"
entity DAO as "DemandeMedicamentRepository"

ref over Demandeur, UI
  S'authentifier
end ref

Demandeur -> UI : 1 : Creer demande (patient, medicament, quantite)
UI -> Controller : 2 : POST /demandes-medicament
Controller -> Service : 3 : creerDemande(dto)
Service -> DAO : 4 : save(statut EN_ATTENTE)
Service --> Controller : 5 : Demande creee
Controller --> UI : 6 : 201 Created

Pharmacien -> UI : 7 : Consulter file des demandes
UI -> Controller : 8 : GET /demandes-medicament?statut=EN_ATTENTE
Controller --> UI : 9 : Liste des demandes
Pharmacien -> UI : 10 : Valider la demande
UI -> Controller : 11 : PATCH /demandes-medicament/{id}/valider
Controller -> Service : 12 : validerDemande(id)
Service -> Stock : 13 : verifierEtDecrementerStock(medicament, qte)

alt Stock insuffisant
  Service -> DAO : 14 : save(statut REFUSEE + motif)
  Service --> Controller : 15 : Erreur stock
  Controller --> UI : 16 : 409 Conflict
  UI --> Pharmacien : 17 : Afficher refus avec motif
else Stock suffisant
  Stock --> Service : 14 : Stock decremente
  Service -> DAO : 15 : save(statut VALIDEE)
  Service --> Controller : 16 : Demande validee
  Controller --> UI : 17 : 200 OK
  UI --> Pharmacien : 18 : Notifier demandeur + succes
end

@enduml

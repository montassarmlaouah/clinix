@startuml
!theme plain

title Diagramme de cas d'utilisation - Dashboards et notifications (Sprint 6)

left to right direction
skinparam packageStyle rectangle

actor "Utilisateur authentifie" as USER
actor "Administrateur clinique" as AC

rectangle "Module Pilotage & Supervision" {
  usecase "Consulter un dashboard adapte au role" as UC1
  usecase "Suivre les indicateurs cles (KPI)" as UC2
  usecase "Visualiser des graphiques dynamiques" as UC3
  usecase "Filtrer les statistiques par periode" as UC4
  usecase "Exporter les statistiques (image / PDF)" as UC5
  usecase "Consulter le centre de notifications" as UC6
  usecase "Marquer une notification lu / non lu" as UC7
}

USER --> UC1
USER --> UC3
USER --> UC4
USER --> UC5
USER --> UC6
USER --> UC7

AC --> UC2

UC1 ..> UC3 : <<include>>
UC3 ..> UC4 : <<extend>>
UC3 ..> UC5 : <<extend>>
UC6 ..> UC7 : <<include>>

@enduml

@startuml
!theme plain

title sd [CRUD - Demande operation]

actor Medecin as "Medecin"
boundary UI as ":UI Demandes operation"
control Controller as "DemandeOperationController"
control Service as "DemandeOperationService"
entity DAO as "DemandeOperationRepository"

== Creer ==


autonumber

ref over Medecin, UI
  S'authentifier
end ref


Medecin -> UI : Cliquer Creer / Nouveau
UI --> Medecin : Afficher formulaire
Medecin -> UI : Remplir et confirmer
UI -> Controller : POST /api/demandes-operation
Controller -> Service : creer(dto)
Service -> DAO : save(entity)
DAO --> Service : Entity creee
Service --> Controller : Entity
Controller --> UI : 201 Created
UI --> Medecin : Message de succes

== Consulter la liste ==

autonumber

ref over Medecin, UI
  S'authentifier
end ref


Medecin -> UI : Ouvrir la liste
UI -> Controller : GET /api/demandes-operation?cliniqueId=...
Controller -> Service : listerParClinique()
Service -> DAO : findAll() / findByClinique(...)
DAO --> Service : Liste
Service --> Controller : List
Controller --> UI : 200 OK
UI --> Medecin : Afficher la liste

== Consulter le detail ==

autonumber

ref over Medecin, UI
  S'authentifier
end ref


Medecin -> UI : Cliquer sur un element
UI -> Controller : GET /api/demandes-operation/{id}
Controller -> Service : obtenir(id)
Service -> DAO : findById(id)

alt [Element introuvable]
  DAO --> Service : empty
  Service --> Controller : NotFoundException
  Controller --> UI : 404 Not Found
  UI --> Medecin : Message d'erreur
else [Element trouve]
  DAO --> Service : Entity
  Service --> Controller : Entity
  Controller --> UI : 200 OK
  UI --> Medecin : Afficher le detail
end

== Modifier ==

autonumber

ref over Medecin, UI
  S'authentifier
end ref


Medecin -> UI : Cliquer Modifier
UI --> Medecin : Afficher formulaire pre-rempli
Medecin -> UI : Modifier les champs et confirmer
UI -> Controller : PATCH /api/demandes-operation/{id}/statut
Controller -> Service : changerStatut(id, dto)
Service -> DAO : findById(id)
DAO --> Service : Entity

alt [Donnees invalides]
  Service --> Controller : Erreur validation
  Controller --> UI : 400 Bad Request
  UI --> Medecin : Afficher erreurs
else [Modification valide]
  Service -> DAO : save(entity)
  DAO --> Service : Entity mise a jour
  Service --> Controller : Entity
  Controller --> UI : 200 OK
  UI --> Medecin : Message de succes
end

== Supprimer ==

autonumber

ref over Medecin, UI
  S'authentifier
end ref


Medecin -> UI : Cliquer Supprimer
UI --> Medecin : Boite de confirmation
Medecin -> UI : Confirmer la suppression
UI -> Controller : DELETE /api/demandes-operation/{id}
Controller -> Service : annuler(id)
Service -> DAO : findById(id)

alt [Suppression impossible (contrainte metier)]
  Service --> Controller : RuntimeException
  Controller --> UI : 400 Bad Request
  UI --> Medecin : Afficher message d'erreur
else [Suppression valide]
  Service -> DAO : delete(entity)
  DAO --> Service : OK
  Service --> Controller : void
  Controller --> UI : 204 No Content
  UI --> Medecin : Element supprime
end

@enduml

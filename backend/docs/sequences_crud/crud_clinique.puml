@startuml
!theme plain

title sd [CRUD - Clinique]

actor Super_administrateur as "Super administrateur"
boundary UI as ":UI Cliniques"
control Controller as "CliniqueController"
control Service as "CliniqueService"
entity DAO as "CliniqueRepository"

== Creer ==


autonumber

ref over Super_administrateur, UI
  S'authentifier
end ref


Super_administrateur -> UI : Cliquer Creer / Nouveau
UI --> Super_administrateur : Afficher formulaire
Super_administrateur -> UI : Remplir et confirmer
UI -> Controller : POST /api/cliniques
Controller -> Service : creerClinique(dto)
Service -> DAO : save(entity)
DAO --> Service : Entity creee
Service --> Controller : Entity
Controller --> UI : 201 Created
UI --> Super_administrateur : Message de succes

== Consulter la liste ==

autonumber

ref over Super_administrateur, UI
  S'authentifier
end ref


Super_administrateur -> UI : Ouvrir la liste
UI -> Controller : GET /api/cliniques
Controller -> Service : listerCliniques()
Service -> DAO : findAll() / findByClinique(...)
DAO --> Service : Liste
Service --> Controller : List
Controller --> UI : 200 OK
UI --> Super_administrateur : Afficher la liste

== Consulter le detail ==

autonumber

ref over Super_administrateur, UI
  S'authentifier
end ref


Super_administrateur -> UI : Cliquer sur un element
UI -> Controller : GET /api/cliniques/{id}
Controller -> Service : obtenirParId(id)
Service -> DAO : findById(id)

alt [Element introuvable]
  DAO --> Service : empty
  Service --> Controller : NotFoundException
  Controller --> UI : 404 Not Found
  UI --> Super_administrateur : Message d'erreur
else [Element trouve]
  DAO --> Service : Entity
  Service --> Controller : Entity
  Controller --> UI : 200 OK
  UI --> Super_administrateur : Afficher le detail
end

== Modifier ==

autonumber

ref over Super_administrateur, UI
  S'authentifier
end ref


Super_administrateur -> UI : Cliquer Modifier
UI --> Super_administrateur : Afficher formulaire pre-rempli
Super_administrateur -> UI : Modifier les champs et confirmer
UI -> Controller : PUT /api/cliniques/{id}
Controller -> Service : mettreAJour(id, dto)
Service -> DAO : findById(id)
DAO --> Service : Entity

alt [Donnees invalides]
  Service --> Controller : Erreur validation
  Controller --> UI : 400 Bad Request
  UI --> Super_administrateur : Afficher erreurs
else [Modification valide]
  Service -> DAO : save(entity)
  DAO --> Service : Entity mise a jour
  Service --> Controller : Entity
  Controller --> UI : 200 OK
  UI --> Super_administrateur : Message de succes
end

== Supprimer ==

autonumber

ref over Super_administrateur, UI
  S'authentifier
end ref


Super_administrateur -> UI : Cliquer Supprimer
UI --> Super_administrateur : Boite de confirmation
Super_administrateur -> UI : Confirmer la suppression
UI -> Controller : DELETE /api/cliniques/{id}
Controller -> Service : supprimer(id)
Service -> DAO : findById(id)

alt [Suppression impossible (contrainte metier)]
  Service --> Controller : RuntimeException
  Controller --> UI : 400 Bad Request
  UI --> Super_administrateur : Afficher message d'erreur
else [Suppression valide]
  Service -> DAO : delete(entity)
  DAO --> Service : OK
  Service --> Controller : void
  Controller --> UI : 204 No Content
  UI --> Super_administrateur : Element supprime
end

@enduml

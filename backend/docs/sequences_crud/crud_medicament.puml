@startuml
!theme plain

title sd [CRUD - Medicament]

actor Pharmacien as "Pharmacien"
boundary UI as ":UI Pharmacie"
control Controller as "MedicamentController"
control Service as "MedicamentService"
entity DAO as "MedicamentRepository"

== Creer ==


autonumber

ref over Pharmacien, UI
  S'authentifier
end ref


Pharmacien -> UI : Cliquer Creer / Nouveau
UI --> Pharmacien : Afficher formulaire
Pharmacien -> UI : Remplir et confirmer
UI -> Controller : POST /api/medicaments
Controller -> Service : creerMedicament(dto)
Service -> DAO : save(entity)
DAO --> Service : Entity creee
Service --> Controller : Entity
Controller --> UI : 201 Created
UI --> Pharmacien : Message de succes

== Consulter la liste ==

autonumber

ref over Pharmacien, UI
  S'authentifier
end ref


Pharmacien -> UI : Ouvrir la liste
UI -> Controller : GET /api/medicaments
Controller -> Service : listerMedicaments()
Service -> DAO : findAll() / findByClinique(...)
DAO --> Service : Liste
Service --> Controller : List
Controller --> UI : 200 OK
UI --> Pharmacien : Afficher la liste

== Consulter le detail ==

autonumber

ref over Pharmacien, UI
  S'authentifier
end ref


Pharmacien -> UI : Cliquer sur un element
UI -> Controller : GET /api/medicaments/{id}
Controller -> Service : obtenirParId(id)
Service -> DAO : findById(id)

alt [Element introuvable]
  DAO --> Service : empty
  Service --> Controller : NotFoundException
  Controller --> UI : 404 Not Found
  UI --> Pharmacien : Message d'erreur
else [Element trouve]
  DAO --> Service : Entity
  Service --> Controller : Entity
  Controller --> UI : 200 OK
  UI --> Pharmacien : Afficher le detail
end

== Modifier ==

autonumber

ref over Pharmacien, UI
  S'authentifier
end ref


Pharmacien -> UI : Cliquer Modifier
UI --> Pharmacien : Afficher formulaire pre-rempli
Pharmacien -> UI : Modifier les champs et confirmer
UI -> Controller : PUT /api/medicaments/{id}
Controller -> Service : mettreAJour(id, dto)
Service -> DAO : findById(id)
DAO --> Service : Entity

alt [Donnees invalides]
  Service --> Controller : Erreur validation
  Controller --> UI : 400 Bad Request
  UI --> Pharmacien : Afficher erreurs
else [Modification valide]
  Service -> DAO : save(entity)
  DAO --> Service : Entity mise a jour
  Service --> Controller : Entity
  Controller --> UI : 200 OK
  UI --> Pharmacien : Message de succes
end

== Supprimer ==

autonumber

ref over Pharmacien, UI
  S'authentifier
end ref


Pharmacien -> UI : Cliquer Supprimer
UI --> Pharmacien : Boite de confirmation
Pharmacien -> UI : Confirmer la suppression
UI -> Controller : DELETE /api/medicaments/{id}
Controller -> Service : supprimer(id)
Service -> DAO : findById(id)

alt [Suppression impossible (contrainte metier)]
  Service --> Controller : RuntimeException
  Controller --> UI : 400 Bad Request
  UI --> Pharmacien : Afficher message d'erreur
else [Suppression valide]
  Service -> DAO : delete(entity)
  DAO --> Service : OK
  Service --> Controller : void
  Controller --> UI : 204 No Content
  UI --> Pharmacien : Element supprime
end

@enduml

@startuml
!theme plain

title sd [CRUD - Rendez-vous]

actor Secretaire as "Secretaire"
boundary UI as ":UI Rendez-vous"
control Controller as "RendezVousController"
control Service as "RendezVousService"
entity DAO as "RendezVousRepository"

== Creer ==


autonumber

ref over Secretaire, UI
  S'authentifier
end ref


Secretaire -> UI : Cliquer Creer / Nouveau
UI --> Secretaire : Afficher formulaire
Secretaire -> UI : Remplir et confirmer
UI -> Controller : POST /api/rendez-vous
Controller -> Service : planifier(dto)
Service -> DAO : save(entity)
DAO --> Service : Entity creee
Service --> Controller : Entity
Controller --> UI : 201 Created
UI --> Secretaire : Message de succes

== Consulter la liste ==

autonumber

ref over Secretaire, UI
  S'authentifier
end ref


Secretaire -> UI : Ouvrir la liste
UI -> Controller : GET /api/rendez-vous/clinique/{cliniqueId}
Controller -> Service : listerParClinique()
Service -> DAO : findAll() / findByClinique(...)
DAO --> Service : Liste
Service --> Controller : List
Controller --> UI : 200 OK
UI --> Secretaire : Afficher la liste

== Consulter le detail ==

autonumber

ref over Secretaire, UI
  S'authentifier
end ref


Secretaire -> UI : Cliquer sur un element
UI -> Controller : GET /api/rendez-vous/{id}
Controller -> Service : obtenirParId(id)
Service -> DAO : findById(id)

alt [Element introuvable]
  DAO --> Service : empty
  Service --> Controller : NotFoundException
  Controller --> UI : 404 Not Found
  UI --> Secretaire : Message d'erreur
else [Element trouve]
  DAO --> Service : Entity
  Service --> Controller : Entity
  Controller --> UI : 200 OK
  UI --> Secretaire : Afficher le detail
end

== Modifier ==

autonumber

ref over Secretaire, UI
  S'authentifier
end ref


Secretaire -> UI : Cliquer Modifier
UI --> Secretaire : Afficher formulaire pre-rempli
Secretaire -> UI : Modifier les champs et confirmer
UI -> Controller : PUT /api/rendez-vous/{id}
Controller -> Service : mettreAJour(id, dto)
Service -> DAO : findById(id)
DAO --> Service : Entity

alt [Donnees invalides]
  Service --> Controller : Erreur validation
  Controller --> UI : 400 Bad Request
  UI --> Secretaire : Afficher erreurs
else [Modification valide]
  Service -> DAO : save(entity)
  DAO --> Service : Entity mise a jour
  Service --> Controller : Entity
  Controller --> UI : 200 OK
  UI --> Secretaire : Message de succes
end

== Supprimer ==

autonumber

ref over Secretaire, UI
  S'authentifier
end ref


Secretaire -> UI : Cliquer Supprimer
UI --> Secretaire : Boite de confirmation
Secretaire -> UI : Confirmer la suppression
UI -> Controller : DELETE /api/rendez-vous/{id}
Controller -> Service : annuler(id)
Service -> DAO : findById(id)

alt [Suppression impossible (contrainte metier)]
  Service --> Controller : RuntimeException
  Controller --> UI : 400 Bad Request
  UI --> Secretaire : Afficher message d'erreur
else [Suppression valide]
  Service -> DAO : delete(entity)
  DAO --> Service : OK
  Service --> Controller : void
  Controller --> UI : 204 No Content
  UI --> Secretaire : Element supprime
end

@enduml

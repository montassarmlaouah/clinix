@startuml
!theme plain

title Diagramme de cas d'utilisation - Gestion des abonnements

left to right direction
skinparam packageStyle rectangle

actor "Super administrateur" as SA
actor "Administrateur clinique" as AC
actor "Secretaire" as SEC
actor "Stripe" as Stripe

rectangle "Module abonnement Luna" {
  usecase "Gerer catalogue offres" as UC1
  usecase "Synchroniser prix Stripe" as UC2
  usecase "Configurer cles Stripe" as UC3
  usecase "Consulter abonnements actifs/payes" as UC4
  usecase "Souscrire via Checkout Stripe" as UC5
  usecase "Simuler souscription (dev)" as UC6
  usecase "Consulter abonnement courant" as UC7
  usecase "Consulter historique abonnements" as UC8
  usecase "Verifier quota SMS offre" as UC9
  usecase "Traiter webhooks Stripe" as UC10
}

SA --> UC1
SA --> UC2
SA --> UC3
SA --> UC4

AC --> UC5
AC --> UC7
SEC --> UC5
SEC --> UC8
AC --> UC9

AC ..> UC6 : <<extend>>\nmode test
SEC ..> UC6 : <<extend>>

Stripe --> UC10
UC5 ..> UC10 : <<include>>

@enduml

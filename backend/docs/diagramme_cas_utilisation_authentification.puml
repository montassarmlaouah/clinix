@startuml
!theme plain

title Diagramme de cas d'utilisation - Authentification et securite (Sprint 1)

left to right direction
skinparam packageStyle rectangle

actor "Utilisateur (tous roles)" as USER
actor "Administrateur" as ADMIN
actor "TunisieSMS" as SMS

rectangle "Module Authentification & Securite" {
  usecase "Se connecter (telephone + mot de passe)" as UC1
  usecase "Se deconnecter" as UC2
  usecase "Demander une reinitialisation de mot de passe" as UC3
  usecase "Recevoir un code OTP par SMS" as UC4
  usecase "Valider l'OTP et definir un nouveau mot de passe" as UC5
  usecase "Consulter son profil" as UC6
  usecase "Modifier ses informations personnelles" as UC7
  usecase "Changer son mot de passe" as UC8
  usecase "Gerer les roles et permissions" as UC9
  usecase "Consulter l'historique des connexions" as UC10
}

USER --> UC1
USER --> UC2
USER --> UC3
USER --> UC5
USER --> UC6
USER --> UC7
USER --> UC8

ADMIN --> UC9
ADMIN --> UC10

UC3 ..> UC4 : <<include>>
UC4 --> SMS
UC7 ..> UC8 : <<extend>>

@enduml

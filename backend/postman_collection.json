            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Patient stabilisé, SpO2 remontée à 96%. Transfert en pneumologie pour surveillance.\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/urgences/{{urgenceId}}/resoudre" }
          }
        },
        {
          "name": "Urgences par patient",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/urgences/patient/{{patientId}}" }
          }
        }
